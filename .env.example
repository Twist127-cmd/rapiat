# =====================================================================
# Rapiat — variables d'environnement.
# Copier ce fichier en `.env` puis remplir. L'application REFUSE de
# démarrer si une variable requise est absente ou malformée
# (validation Zod dans src/lib/env.ts).
# =====================================================================

# --- Base de données PostgreSQL (Neon) ------------------------------
# URL avec pooling (utilisée par l'application à l'exécution, HTTPS port 443).
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
# URL directe SANS pooling (utilisée par Prisma Migrate / introspection).
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# --- Authentification (Auth.js / NextAuth v5) -----------------------
# Générer un secret fort : `openssl rand -base64 32`
AUTH_SECRET="remplacer-par-un-secret-aleatoire-de-32-octets-minimum"
# URL publique de l'application (facultatif en dev, requis en prod).
AUTH_URL="http://localhost:3000"

# --- Divers ---------------------------------------------------------
# Nom de l'application affiché dans l'UI (valeur publique, non secrète).
NEXT_PUBLIC_APP_NAME="Rapiat"

# Autoriser la création de compte (inscription). "true" par défaut.
NEXT_PUBLIC_ALLOW_SIGNUP="true"
